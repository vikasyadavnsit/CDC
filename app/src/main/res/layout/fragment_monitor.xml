<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="◉ Monitor Logs"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium" />

            <ImageView
                android:id="@+id/monitor_clear_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="6dp"
                android:src="@drawable/ic_delete"
                android:contentDescription="Clear logs"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_secondary" />
        </LinearLayout>

        <!-- Search Bar -->
        <EditText
            android:id="@+id/monitor_search_edit_text"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/input_field_bg"
            android:hint="Search logs..."
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:paddingHorizontal="16dp"
            android:maxLines="1"
            android:inputType="text"
            android:drawableStart="@drawable/ic_nav_monitor"
            android:drawablePadding="10dp"
            app:drawableTint="@color/text_hint" />

    </LinearLayout>

    <!-- Log list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/monitor_log_rv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/monitor_empty_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No logs captured yet.\nMonitoring activities will appear here."
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.6"
        android:fontFamily="sans-serif-light"
        android:visibility="gone" />

</LinearLayout>

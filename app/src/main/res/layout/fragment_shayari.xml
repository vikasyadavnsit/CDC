<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/shayari_fragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/shayari_bg_start"
    android:orientation="vertical"
    android:gravity="center">

    <!-- Subtle section label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="✦  Shayari  ✦"
        android:textColor="@color/shayari_text_secondary"
        android:textSize="12sp"
        android:letterSpacing="0.2"
        android:fontFamily="sans-serif-medium" />

    <!-- Shayari card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        app:cardBackgroundColor="@color/shayari_card_bg"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Opening quote -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x201C;"
                android:textColor="@color/shayari_quote_mark"
                android:textSize="72sp"
                android:lineSpacingMultiplier="0.5"
                android:fontFamily="serif" />

            <!-- Shayari text -->
            <TextView
                android:id="@+id/shayari_fragment_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-16dp"
                android:text="@string/hello_blank_fragment"
                android:textColor="@color/shayari_text_primary"
                android:textSize="19sp"
                android:lineSpacingMultiplier="1.8"
                android:textAlignment="center"
                android:fontFamily="serif"
                android:letterSpacing="0.02" />

            <!-- Closing quote -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="&#x201D;"
                android:textColor="@color/shayari_quote_mark"
                android:textSize="72sp"
                android:textAlignment="textEnd"
                android:lineSpacingMultiplier="0.5"
                android:fontFamily="serif" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/spending_back_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_right"
            android:rotation="180"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            app:tint="@color/text_secondary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="₹ Spending"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="12dp" />

    </LinearLayout>

    <!-- Period selector -->
    <Spinner
        android:id="@+id/spending_period_spinner"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/spinner_bg"
        android:paddingHorizontal="12dp"
        android:popupBackground="@color/surface_variant" />

    <!-- Type filter -->
    <RadioGroup
        android:id="@+id/spending_type_filter"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="10dp">

        <RadioButton
            android:id="@+id/filter_type_all"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="All"
            android:checked="true"
            android:textSize="12sp"
            android:gravity="center"
            android:button="@null"
            android:layout_marginEnd="4dp" />

        <RadioButton
            android:id="@+id/filter_type_debit"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Debit"
            android:textSize="12sp"
            android:gravity="center"
            android:button="@null"
            android:layout_marginEnd="4dp" />

        <RadioButton
            android:id="@+id/filter_type_credit"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Credit"
            android:textSize="12sp"
            android:gravity="center"
            android:button="@null" />

    </RadioGroup>

    <!-- Summary card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/primary_container"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/spending_summary_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/spending_total_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹ 0"
                android:textColor="@color/text_primary"
                android:textSize="32sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/spending_txn_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 transactions"
                android:textColor="@color/text_hint"
                android:textSize="12sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Category chips -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/spending_category_rv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:paddingHorizontal="12dp"
        android:clipToPadding="false"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- Loading state -->
    <TextView
        android:id="@+id/spending_loading_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Parsing SMS transactions..."
        android:textColor="@color/text_hint"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="12dp"
        android:visibility="gone" />

    <!-- Transactions list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/spending_transaction_rv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

</LinearLayout>

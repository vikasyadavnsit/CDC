<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/shayari_card_bg"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/item_shayari_index"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:textColor="@color/shayari_quote_mark"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/shayari_counter_bg" />

        <TextView
            android:id="@+id/item_shayari_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textColor="@color/shayari_text_primary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"
            android:fontFamily="serif"
            android:maxLines="3"
            android:ellipsize="end" />

    </LinearLayout>

</androidx.cardview.widget.CardView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_raised_bg"
    android:clipToOutline="true">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tag Transaction"
        android:textColor="@color/text_primary"
        android:textSize="17sp"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp" />

    <!-- SMS preview — scrollable so message is never trimmed -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/input_field_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/dialog_sms_sender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:layout_marginBottom="5dp" />

            <TextView
                android:id="@+id/dialog_sms_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- TYPE -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TYPE"
        android:textColor="@color/text_hint"
        android:textSize="10sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.15"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="6dp" />

    <Spinner
        android:id="@+id/dialog_type_spinner"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/spinner_bg"
        android:paddingHorizontal="12dp"
        android:popupBackground="@color/surface_variant"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="14dp" />

    <!-- CATEGORY -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CATEGORY"
        android:textColor="@color/text_hint"
        android:textSize="10sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.15"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="6dp" />

    <Spinner
        android:id="@+id/dialog_category_spinner"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/spinner_bg"
        android:paddingHorizontal="12dp"
        android:popupBackground="@color/surface_variant"
        android:layout_marginHorizontal="20dp" />

    <!-- Divider above buttons -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="16dp" />

    <!-- Button row: [Delete] ···spacer··· [Cancel] [Save] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <TextView
            android:id="@+id/dialog_btn_delete"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Delete"
            android:textColor="@color/spending_debit"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/dialog_btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Cancel"
            android:textColor="@color/text_hint"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/dialog_btn_save"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Save"
            android:textColor="@color/on_primary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:background="@drawable/rounded_button" />

    </LinearLayout>

</LinearLayout>

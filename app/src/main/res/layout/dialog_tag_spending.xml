<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg"
    android:padding="20dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tag Transaction"
        android:textColor="@color/text_primary"
        android:textSize="17sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="14dp" />

    <!-- SMS preview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/input_field_bg"
        android:padding="12dp"
        android:layout_marginBottom="18dp">

        <TextView
            android:id="@+id/dialog_sms_sender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:layout_marginBottom="5dp" />

        <TextView
            android:id="@+id/dialog_sms_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.3"
            android:maxLines="5"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- TYPE -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TYPE"
        android:textColor="@color/text_hint"
        android:textSize="10sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.15"
        android:layout_marginBottom="6dp" />

    <Spinner
        android:id="@+id/dialog_type_spinner"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/spinner_bg"
        android:paddingHorizontal="12dp"
        android:popupBackground="@color/surface_variant"
        android:layout_marginBottom="16dp" />

    <!-- CATEGORY -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CATEGORY"
        android:textColor="@color/text_hint"
        android:textSize="10sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.15"
        android:layout_marginBottom="6dp" />

    <Spinner
        android:id="@+id/dialog_category_spinner"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/spinner_bg"
        android:paddingHorizontal="12dp"
        android:popupBackground="@color/surface_variant"
        android:layout_marginBottom="4dp" />

</LinearLayout>
